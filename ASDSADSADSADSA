local function getAvailableConfigs()
local list = {"Default"}
if listfiles and isfolder and isfolder(folderName) then
local files = listfiles(folderName)
for _, file in ipairs(files) do
local name = file:match("([^/\\]+)%.json$")
if name and name ~= "Default" then
table.insert(list, name)
end
end
end
return list
end

local function saveConfigProfile(name)
if writefile then
local targetPath = folderName .. "/" .. name .. ".json"
writefile(targetPath, HttpService:JSONEncode(state))
LogDebug("Config", "Profile saved to: " .. targetPath)
end
end

local function loadConfigProfile(name)
if readfile and isfile then
local targetPath = folderName .. "/" .. name .. ".json"
if isfile(targetPath) then
local ok, data = pcall(function() return HttpService:JSONDecode(readfile(targetPath)) end)
if ok and type(data) == "table" then
for k, v in pairs(data) do
if state[k] ~= nil then state[k] = v end
end
LogDebug("Config", "Profile loaded from: " .. targetPath)
return true
end
end
end
return false
end

local function saveGlobalMetadata()
