local function tpToTarget(targetInstance, offset)
if not targetInstance then
Notify("Teleport Failed", "Target path does not exist dynamically.", "solar:close-circle-bold")
return
end

local char = LocalPlayer.Character
local root = char and char:FindFirstChild("HumanoidRootPart")
if root then
local cframe
if targetInstance:IsA("Model") then
cframe = (targetInstance.PrimaryPart and targetInstance.PrimaryPart.CFrame) or targetInstance:GetPivot()
elseif targetInstance:IsA("BasePart") then
cframe = targetInstance.CFrame
end

if cframe then
stopVelocity(root)
root.CFrame = cframe + (offset or Vector3.new(0, 3, 0))
LogDebug("Teleport", "Jumped to " .. targetInstance.Name)
end
end
end

local function equipFirstInventoryItem()
local char = LocalPlayer.Character
local humanoid = char and char:FindFirstChildOfClass("Humanoid")
local backpack = LocalPlayer:FindFirstChild("Backpack")

if humanoid and backpack then
if char:FindFirstChildOfClass("Tool") then return true end
local firstItem = backpack:FindFirstChildOfClass("Tool")
if firstItem then
humanoid:EquipTool(firstItem)
return true
end
end
return false
end

local function getAttackRemote()
local char = LocalPlayer.Character
if not char then return nil end
local remotes = {"Attack", "Combat", "Hit"}

for _, name in ipairs(remotes) do
local r = char:FindFirstChild(name, true) or (LocalPlayer:FindFirstChild("Backpack") and LocalPlayer.Backpack:FindFirstChild(name, true)) or ReplicatedStorage:FindFirstChild(name, true)
if r and (r:IsA("RemoteEvent") or r:IsA("UnreliableRemoteEvent")) then return r end
end
return nil
end

local function getTycoon(isMine)
local kit = Workspace:FindFirstChild("Zednov's Tycoon Kit") or Workspace:FindFirstChild("Tycoon Kit", true)
local folder = kit and (kit:FindFirstChild("Tycoons") or kit:FindFirstChild("TycoonFolder", true))
if not folder then return nil end

for _, tycoon in pairs(folder:GetChildren()) do
local owner = tycoon:FindFirstChild("Owner")
if isMine and owner and owner.Value == LocalPlayer then return tycoon
elseif not isMine and owner and owner.Value ~= LocalPlayer and owner.Value ~= nil then return tycoon end
end
return nil
end

local function serverHop()
Notify("Server Hop", "Finding a different cosmic server...", "solar:restart-bold")
task.wait(0.5)
local servers = {}
pcall(function()
local res = game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
local data = HttpService:JSONDecode(res)
for _, server in ipairs(data.data) do
if server.playing < server.maxPlayers and server.id ~= game.JobId then
table.insert(servers, server.id)
end
end
end)
if #servers > 0 then
TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], LocalPlayer)
else
Notify("Server Hop Failed", "No planetary nodes discovered.", "solar:close-circle-bold")
end
end

local espCache = {}

local function createESP(player)
if player == LocalPlayer or espCache[player] then return end

local hl = Instance.new("Highlight")
hl.FillColor = Color3.fromRGB(0, 229, 255)
hl.OutlineColor = Color3.fromRGB(123, 44, 191)
hl.FillTransparency = 0.5
hl.Enabled = false

local bb = Instance.new("BillboardGui")
bb.Size = UDim2.new(0, 200, 0, 50)
bb.StudsOffset = Vector3.new(0, 3.5, 0)
bb.AlwaysOnTop = true
bb.Enabled = false

local txt = Instance.new("TextLabel", bb)
txt.Size = UDim2.new(1, 0, 1, 0)
txt.BackgroundTransparency = 1
txt.TextScaled = false
txt.TextSize = 14
txt.TextColor3 = Color3.fromRGB(0, 225, 255)
txt.Font = Enum.Font.GothamBold
txt.TextStrokeTransparency = 0
txt.TextStrokeColor3 = Color3.fromRGB(11, 16, 33)

espCache[player] = { Highlight = hl, Billboard = bb, TextLabel = txt }
end

local function removeESP(player)
if espCache[player] then
espCache[player].Highlight:Destroy()
espCache[player].Billboard:Destroy()
espCache[player] = nil
end
end

Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)
for _, p in ipairs(Players:GetPlayers()) do createESP(p) end

local freecamCFrame = CFrame.new()
local freecamSpeed = 1.6
local freecamRotX, freecamRotY = 0, 0

RunService.RenderStepped:Connect(function()
local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

for player, data in pairs(espCache) do
local char = player.Character
local root = char and char:FindFirstChild("HumanoidRootPart")
local hum = char and char:FindFirstChildOfClass("Humanoid")

if char and root and hum and hum.Health > 0 and myRoot then
data.Highlight.Parent = char
data.Billboard.Parent = root
data.Highlight.Enabled = state.espPlayers

if state.espNames or state.espDistance then
data.Billboard.Enabled = true
local textStr = ""
if state.espNames then
textStr = textStr .. player.DisplayName .. "\n<font color='#00E5FF'>@" .. player.Name .. "</font>"
end
if state.espDistance then
local dist = math.floor((root.Position - myRoot.Position).Magnitude)
if textStr ~= "" then textStr = textStr .. "\n" end
textStr = textStr .. "<font color='#7B2CBF'>[" .. dist .. "m]</font>"
end
data.TextLabel.RichText = true
data.TextLabel.Text = textStr
else
data.Billboard.Enabled = false
end
else
data.Highlight.Enabled = false
data.Billboard.Enabled = false
end
end

if state.freeCam then
local cam = Workspace.CurrentCamera
if cam then
cam.CameraType = Enum.CameraType.Scriptable
local moveVector = Vector3.new()
if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + cam.CFrame.LookVector end
if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - cam.CFrame.LookVector end
if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - cam.CFrame.RightVector end
if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + cam.CFrame.RightVector end
if UserInputService:IsKeyDown(Enum.KeyCode.E) then moveVector = moveVector + Vector3.new(0, 1, 0) end
if UserInputService:IsKeyDown(Enum.KeyCode.Q) then moveVector = moveVector - Vector3.new(0, 1, 0) end

if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
local delta = UserInputService:GetMouseDelta()
freecamRotY = freecamRotY - delta.X * 0.003
freecamRotX = math.clamp(freecamRotX - delta.Y * 0.003, -math.rad(89), math.rad(89))
else
UserInputService.MouseBehavior = Enum.MouseBehavior.Default
end

freecamCFrame = CFrame.new(freecamCFrame.Position + moveVector * freecamSpeed) * CFrame.Angles(0, freecamRotY, 0) * CFrame.Angles(freecamRotX, 0, 0)
cam.CFrame = freecamCFrame
end
end
end)

